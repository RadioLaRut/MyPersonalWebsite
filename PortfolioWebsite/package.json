    "lucide-react": "^0.576.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
