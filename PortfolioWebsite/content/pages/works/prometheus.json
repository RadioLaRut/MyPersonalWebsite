        {
            "type": "RichParagraph",
            "props": {
                "id": "prometheus-desc-1",
                "content": "PROMETHEUS 是一款潜行拍摄游戏。在类似《万神殿》的科幻世界观中，各国政府秘密研发 Upload Intelligence 技术。玩家扮演一位记者，潜入政府大楼试图曝光这一惊人秘密。游戏的核心机制是资源管理与策略规划：玩家携带有限数量的胶卷，需要在躲避巡逻的同时，拍摄尽可能多的目标人物以获取更高分数。不同目标具有不同的优先级权重，玩家还可以操纵场景中的机关来创造拍摄机会或规避风险。这是一个在 1-2 周内完成的课程作业 Demo，我主要负责关卡设计、机制设计和项目管理。"
            }
        },
        {
            "type": "HighDensityInfoBlock",
            "props": {
                "id": "prometheus-info-1",
                "phase1Title": "项目背景",
                "phase1Subtitle": "Context",
                "phase1Content": "作为虚幻引擎动画创作课程的结课作业，我与 2-3 人小团队在 1-2 周内完成了这个潜行拍摄游戏 Demo。项目灵感来自《万神殿》的科幻世界观，探索 Upload Intelligence 技术带来的伦理困境。",
                "phase1Items": [
                    { "label": "引擎", "value": "Unreal Engine 5", "_arrayItem": { "id": "item-1" } },
                    { "label": "开发周期", "value": "1-2 周", "_arrayItem": { "id": "item-2" } },
                    { "label": "团队规模", "value": "2-3 人", "_arrayItem": { "id": "item-3" } },
                    { "label": "项目性质", "value": "课程作业", "_arrayItem": { "id": "item-4" } }
                ],
                "phase2Title": "核心机制",
                "phase2Subtitle": "Core Mechanics",
                "phase2Content": "游戏结合了资源管理、潜行和策略规划三大核心机制。玩家需要在有限的胶卷约束下，规划最优的拍摄路线，同时利用场景机关创造机会或规避风险。目标优先级系统鼓励玩家做出策略性选择。",
                "phase2Items": [],
                "phase3Title": "我的贡献",
                "phase3Subtitle": "My Role",
                "phase3Content": "我主要负责关卡设计和项目管理。设计了巡逻路径、拍摄点位布局和机关交互逻辑，确保玩家在紧张的潜行过程中有多种策略选择。同时协调团队分工，在短时间内完成了可玩的 Demo。",
                "phase3ImageSrc": ""
            }
        },
