  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-next-with-mode.mjs normal dev",
    "dev:test": "node scripts/run-next-with-mode.mjs testing dev",
    "build": "npm run test:assets && next build",
    "start": "next start",
