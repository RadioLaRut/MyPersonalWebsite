    {
      "type": "HighDensityInfoBlock",
      "props": {
        "phase2Items": [],
        "phase1Items": [],
        "id": "holytank-info-1",
        "phase1Title": "项目背景",
        "phase1Subtitle": "Context",
        "phase1Content": "敌意建筑时时刻刻充满我们的身边，他们带来了秩序的同时也给城市添加上了一点尖锐和冷漠感我们想尝试探讨敌意建筑是否会给城市中的人带来不便和冷漠。",
        "phase2Title": "核心创新",
        "phase2Subtitle": "Innovation",
        "phase2Content": "游戏的核心创新在于分析并创新轨迹球能带来的操作感觉。玩家需要通过推动轨迹球的感觉来体验推动轮椅的困难，这种操作上的不便与角色的身体残障形成了强烈的通感。游戏通过这种方式让玩家切身感受到敌意建筑对残疾人的影响。",
        "phase3Title": "我的贡献",
        "phase3Subtitle": "My Role",
        "phase3Content": "我主要负责游戏的主题设定和交互实现。设计了轨迹球与轮椅操作的映射逻辑，确保玩家能够通过操作体验到残疾人的困难。同时负责整体系统设计，将敌意建筑的概念融入关卡设计中。",
        "phase3ImageSrc": "",
        "phase1Label": "Phese 01",
        "phase2Label": "Phese 02",
        "phase3Label": "Phese 03"
