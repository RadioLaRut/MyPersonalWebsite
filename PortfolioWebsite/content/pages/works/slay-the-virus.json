        "id": "stv-hero-1",
        "eyebrow": "Project 03",
        "title": "SLAY THE VIRUS",
        "subtitle": "Roguelike 卡牌游戏",
        "heroImage": "/images/slay-the-virus/STVTitle.webp",
        "navLink": "https://www.bilibili.com/video/BV1QfgzzrE3J/",
        "heroImagePreset": "ratio-21-9",
